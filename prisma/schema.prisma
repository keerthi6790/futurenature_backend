generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

generator markdown {
  provider = "prisma-markdown"
  output   = "./prisma.md"
  title    = "FutureNature Backend Schema"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String     @id @default(uuid())
  phone_number    String     @unique
  firstName       String?
  lastName        String?
  hashed_password String?
  is_verified     Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @default(now())
  isAdmin         Boolean    @default(false)
  address         Address[]
  cart            Cart?
  posted_review   Review?
  wishlist        Wishlist[]
  orders          Order[]
}

model Otp {
  id           String @id @default(uuid())
  phone_number String @unique
  otp          String
}

model Product {
  id                 String     @id @default(uuid())
  product_name       String
  description        String
  imageUrl           String[]
  price              String
  available_quantity Int        @default(5)
  description_tamil  String
  discounted_amount  String
  discounted_type    String
  product_name_tamil String
  selling_price      String
  overall_rating     Float      @default(0)
  review_count       Int        @default(0)
  isDailyDeals       Boolean    @default(false)
  isDeleted          Boolean    @default(false)
  reviews            Review[]
  wishlistedBy       Wishlist[]
  cart               CartItem[]
  order_items        OrderItem[]
}

model Review {
  id        String  @id @default(uuid())
  reviewId  String
  review    String
  addedById String  @unique
  rating    Int
  addedBy   User    @relation(fields: [addedById], references: [id])
  Product   Product @relation(fields: [reviewId], references: [id])
}

model Address {
  id           String  @id @default(uuid())
  address1     String
  address2     String
  address3     String
  address4     String?
  pincode      String
  city         String
  district     String
  state        String
  userId       String
  phone_number String
  User         User    @relation(fields: [userId], references: [id])
  orders       Order[]
}

model Cart {
  id               String     @id @default(uuid())
  total_price      String
  discounted_price String
  mrp_price        String
  userId           String     @unique
  user             User       @relation(fields: [userId], references: [id])
  cart_item        CartItem[]
  createdAt        DateTime   @default(now())
}

model CartItem {
  id                String @id @default(uuid())
  selected_quantity String
  total_price       String
  discounted_price  String
  mrp_price         String
  cartId            String
  productId         String
  cart              Cart    @relation(fields: [cartId], references: [id])
  product           Product @relation(fields: [productId], references: [id])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model Order {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  total_price     String
  discounted_price String
  mrp_price       String
  paymentStatus   String      @default("PENDING") // PENDING, PAID, FAILED
  paymentId       String?
  razorpayOrderId String?
  addressId       String
  address         Address     @relation(fields: [addressId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @default(now()) @updatedAt
  items           OrderItem[]
}

model OrderItem {
  id                String  @id @default(uuid())
  orderId           String
  order             Order   @relation(fields: [orderId], references: [id])
  productId         String
  product           Product @relation(fields: [productId], references: [id])
  selected_quantity String
  total_price       String
  discounted_price  String
  mrp_price         String
}
