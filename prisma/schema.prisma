generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

generator markdown {
  provider = "prisma-markdown"
  output   = "./prisma.md"
  title    = "FutureNature Backend Schema"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String     @id @default(uuid())
  phone_number    String     @unique
  firstName       String?
  lastName        String?
  is_verified     Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @default(now())
  isAdmin         Boolean    @default(false)
  dob             DateTime?
  email           String?
  isWhatsappOptIn Boolean    @default(false)
  address         Address[]
  cart            Cart?
  orders          Order[]
  posted_review   Review[]
  wishlist        Wishlist[]
}

model Otp {
  id           String @id @default(uuid())
  phone_number String @unique
  otp          String
}

model Product {
  id                 String      @id @default(uuid())
  product_name       String
  description        String
  imageUrl           String[]
  price              String
  available_quantity Int         @default(5)
  description_tamil  String
  discounted_amount  String
  discounted_type    String
  product_name_tamil String
  selling_price      String
  overall_rating     Float       @default(0)
  review_count       Int         @default(0)
  isDailyDeals       Boolean     @default(false)
  isDeleted          Boolean     @default(false)
  cart               CartItem[]
  order_items        OrderItem[]
  reviews            Review[]
  wishlistedBy       Wishlist[]
}

model Review {
  id        String  @id @default(uuid())
  reviewId  String
  review    String
  addedById String
  rating    Int
  addedBy   User    @relation(fields: [addedById], references: [id])
  Product   Product @relation(fields: [reviewId], references: [id])
}

model Address {
  id           String  @id @default(uuid())
  address1     String
  address2     String
  address3     String
  address4     String?
  pincode      String
  city         String
  district     String
  state        String
  userId       String
  phone_number String
  label        String  @default("Home")
  receiverName String?
  isDeleted    Boolean @default(false)
  User         User    @relation(fields: [userId], references: [id])
  orders       Order[]
  Cart   Cart[]
}

model Cart {
  id               String     @id @default(uuid())
  total_price      String
  discounted_price String
  shippingPrice String @default("0")
  mrp_price        String
  userId           String     @unique
  createdAt        DateTime   @default(now())
  user             User       @relation(fields: [userId], references: [id])
  cart_item        CartItem[]
  addressId String?
  address          Address?     @relation(fields: [addressId], references: [id])
}

model CartItem {
  id                String  @id @default(uuid())
  selected_quantity String
  total_price       String
  discounted_price  String
  mrp_price         String
  cartId            String
  productId         String
  cart              Cart    @relation(fields: [cartId], references: [id])
  product           Product @relation(fields: [productId], references: [id])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model Order {
  id               String      @id @default(uuid())
  userId           String
  total_price      String
  discounted_price String
  shippingPrice String @default("0")
  mrp_price        String
  paymentStatus    String      @default("PENDING")
  paymentId        String?
  razorpayOrderId  String?
  addressId        String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @default(now()) @updatedAt
  address          Address     @relation(fields: [addressId], references: [id])
  user             User        @relation(fields: [userId], references: [id])
  items            OrderItem[]
}

model OrderItem {
  id                String  @id @default(uuid())
  orderId           String
  productId         String
  selected_quantity String
  total_price       String
  discounted_price  String
  mrp_price         String
  order             Order   @relation(fields: [orderId], references: [id])
  product           Product @relation(fields: [productId], references: [id])
}

model Constants{
  id String @id @default(uuid())
  name String
  boolean String
}
